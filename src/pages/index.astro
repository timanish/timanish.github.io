---
const experience = [
  {
    role: 'Software Development Engineer',
    company: 'Mapbox',
    period: 'May 2025 – Present',
    location: 'Remote',
    blurb: 'Building map telemetry and metrics systems. Every map interaction tells a story, and my team makes sure we hear it.',
    tags: ['Data Pipelines', 'Agentic AI', 'Telemetry'],
  },
  {
    role: 'Software Engineer',
    company: 'Amazon',
    period: 'Feb 2024 – May 2025',
    location: 'Dallas, TX',
    blurb: 'Workplace Experience team. Built data pipelines and agentic AI tooling that made office life smarter.',
    tags: ['Agentic AI', 'Data Pipelines'],
  },
  {
    role: 'AI Training & Evaluation Engineer',
    company: 'Mercor',
    period: 'Nov 2023 – Apr 2025',
    location: 'Remote · Contract',
    blurb: 'Evaluated AI agent traces, designed rubrics for reasoning quality and built labeled datasets for fine-tuning. Taught models to think a little straighter.',
    tags: ['AI Evaluation', 'Rubrics', 'Agentic Automation'],
  },
  {
    role: 'Senior Software Engineer',
    company: 'Avalara',
    period: 'Sep 2022 – Dec 2023',
    location: 'Remote',
    blurb: 'Tax compliance at scale. Kept event-driven services humming with Kubernetes and Kafka.',
    tags: ['Kubernetes', 'Apache Kafka'],
  },
  {
    role: 'Software Engineer',
    company: 'Amazon',
    period: 'Aug 2016 – Jul 2022',
    location: 'Remote',
    blurb: 'Six years of microservices, serverless and everything in between. First tour at Amazon, where I learned to build things that survive Prime Day.',
    tags: ['Microservices', 'AWS Lambda', 'AWS'],
  },
];

const skills = {
  'Systems & Infra': ['Distributed Systems', 'Microservices', 'Kubernetes', 'AWS', 'AWS Lambda', 'Cloud Architecture'],
  'Data & APIs': ['Scalable APIs', 'Data Pipelines', 'Apache Kafka', 'Telemetry & Metrics'],
  'AI': ['Agentic AI Development', 'AI Evaluation', 'Evaluation Rubrics', 'Agentic Automation'],
};

const yearsOfExperience = new Date().getFullYear() - 2016;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Anish Timsina · Software Engineer</title>
    <meta
      name="description"
      content="Anish Timsina is a senior software engineer working on distributed systems, cloud infrastructure and scalable APIs. Currently building map telemetry at Mapbox."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="Anish Timsina · Software Engineer" />
    <meta property="og:description" content="Distributed systems, cloud and scalable APIs. Currently at Mapbox." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://timanish.github.io" />
  </head>
  <body>
    <div class="topo" aria-hidden="true">
      <svg width="100%" height="100%" preserveAspectRatio="xMidYMid slice" viewBox="0 0 900 600" xmlns="http://www.w3.org/2000/svg">
        <g fill="none" stroke="var(--topo-line)" stroke-width="1.2">
          <path d="M-50,120 C150,60 280,180 450,140 C620,100 720,200 950,150" />
          <path d="M-50,170 C160,110 290,230 460,190 C630,150 730,250 950,200" />
          <path d="M-50,220 C170,160 300,280 470,240 C640,200 740,300 950,250" />
          <path d="M-50,280 C180,220 310,340 480,300 C650,260 750,360 950,310" />
          <path d="M-50,340 C190,280 320,400 490,360 C660,320 760,420 950,370" />
          <path d="M-50,400 C200,340 330,460 500,420 C670,380 770,480 950,430" />
          <path d="M-50,460 C210,400 340,520 510,480 C680,440 780,540 950,490" />
          <path d="M-50,520 C220,460 350,580 520,540 C690,500 790,600 950,550" />
        </g>
      </svg>
    </div>

    <header class="nav">
      <a class="logo" href="#top">anish<span class="accent">.</span>timsina</a>
      <nav>
        <a href="#about">About</a>
        <a href="#experience">Experience</a>
        <a href="#skills">Skills</a>
        <a href="#contact">Contact</a>
        <button id="theme-toggle" aria-label="Toggle color theme" title="Toggle theme">
          <span class="sun">☀️</span><span class="moon">🌙</span>
        </button>
      </nav>
    </header>

    <main id="top">
      <section class="hero">
        <p class="eyebrow mono">$ whoami<span class="cursor">▊</span></p>
        <h1>Anish Timsina</h1>
        <p class="headline">
          Senior Software Engineer building <strong>distributed systems</strong>,
          <strong>cloud infrastructure</strong> and <strong>scalable APIs</strong>.
        </p>
        <p class="sub">
          Currently making maps smarter at <a href="https://www.mapbox.com" rel="noopener">Mapbox</a>.
          Based in Fort Worth, Texas.
        </p>
        <div class="hero-links">
          <a class="btn primary" href="mailto:timsina.anish@gmail.com">Say hello</a>
          <a class="btn" href="https://www.linkedin.com/in/anishtimsina" rel="noopener">LinkedIn</a>
          <a class="btn" href="https://github.com/timanish" rel="noopener">GitHub</a>
        </div>
        <dl class="stats reveal">
          <div><dt>{yearsOfExperience}+</dt><dd>years shipping software</dd></div>
          <div><dt>2</dt><dd>tours at Amazon</dd></div>
          <div><dt>∞</dt><dd>telemetry events wrangled</dd></div>
        </dl>
      </section>

      <section id="about" class="reveal">
        <h2><span class="mono accent">01.</span> About</h2>
        <p>
          I'm a software engineer with nearly a decade of experience across Amazon, Avalara,
          Mercor and Mapbox. I like systems that stay up, APIs that scale and dashboards that
          tell the truth.
        </p>
        <p>
          These days I work on map telemetry and metrics at Mapbox. Before that I built
          agentic AI tools and data pipelines at Amazon, kept tax software compliant at
          Avalara and taught AI models to reason better at Mercor. I care about product
          reliability, developer productivity and code that doesn't page anyone at 3 am.
        </p>
      </section>

      <section id="experience" class="reveal">
        <h2><span class="mono accent">02.</span> Experience</h2>
        <ol class="timeline">
          {experience.map((job) => (
            <li class="job reveal">
              <div class="job-head">
                <h3>{job.role} <span class="at">@ {job.company}</span></h3>
                <p class="mono period">{job.period} · {job.location}</p>
              </div>
              <p>{job.blurb}</p>
              <ul class="tags">
                {job.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </li>
          ))}
        </ol>
      </section>

      <section id="skills" class="reveal">
        <h2><span class="mono accent">03.</span> Skills</h2>
        <div class="skills-grid">
          {Object.entries(skills).map(([group, items]) => (
            <div class="skill-group">
              <h3 class="mono">{group}</h3>
              <ul class="tags">
                {items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <section id="education" class="reveal">
        <h2><span class="mono accent">04.</span> Education</h2>
        <p>
          <strong>University of Nebraska–Lincoln</strong><br />
          Go Huskers.
        </p>
      </section>

      <section id="contact" class="reveal contact">
        <h2><span class="mono accent">05.</span> Contact</h2>
        <p>
          Whether you want to talk distributed systems, maps or the best momo in Texas,
          my inbox is open.
        </p>
        <a class="btn primary big" href="mailto:timsina.anish@gmail.com">timsina.anish@gmail.com</a>
      </section>
    </main>

    <footer>
      <p class="mono">
        Built with <a href="https://astro.build" rel="noopener">Astro</a> ·
        hosted on GitHub Pages · powered by coffee ☕
      </p>
      <p class="mono dim">© {new Date().getFullYear()} Anish Timsina</p>
    </footer>

    <script>
      const root = document.documentElement;
      const stored = localStorage.getItem('theme');
      if (stored) root.dataset.theme = stored;

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const dark = root.dataset.theme
          ? root.dataset.theme === 'dark'
          : window.matchMedia('(prefers-color-scheme: dark)').matches;
        const next = dark ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>

    <style is:global>
      :root {
        --bg: #f8fafc;
        --bg-card: #ffffff;
        --text: #1e293b;
        --text-dim: #64748b;
        --accent: #059669;
        --accent-soft: #05966915;
        --border: #e2e8f0;
        --topo-line: #05966912;
      }
      :root[data-theme='dark'] {
        --bg: #0f172a;
        --bg-card: #1e293b;
        --text: #e2e8f0;
        --text-dim: #94a3b8;
        --accent: #34d399;
        --accent-soft: #34d39918;
        --border: #33415577;
        --topo-line: #34d39914;
      }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme='light']) {
          --bg: #0f172a;
          --bg-card: #1e293b;
          --text: #e2e8f0;
          --text-dim: #94a3b8;
          --accent: #34d399;
          --accent-soft: #34d39918;
          --border: #33415577;
          --topo-line: #34d39914;
        }
      }

      * { box-sizing: border-box; margin: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.65;
        transition: background 0.3s, color 0.3s;
      }
      .mono {
        font-family: ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.9em;
      }
      .accent { color: var(--accent); }
      .dim { color: var(--text-dim); }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .topo {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 860px;
        margin: 0 auto;
        padding: 1.2rem 1.5rem;
      }
      .nav .logo {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--text);
        font-family: ui-monospace, Menlo, monospace;
      }
      .nav nav { display: flex; align-items: center; gap: 1.1rem; }
      .nav nav a { color: var(--text-dim); font-size: 0.95rem; }
      .nav nav a:hover { color: var(--accent); text-decoration: none; }
      #theme-toggle {
        background: none;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.25rem 0.5rem;
        cursor: pointer;
        font-size: 0.9rem;
      }
      .sun { display: none; }
      .moon { display: inline; }
      :root[data-theme='dark'] .sun { display: inline; }
      :root[data-theme='dark'] .moon { display: none; }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme='light']) .sun { display: inline; }
        :root:not([data-theme='light']) .moon { display: none; }
      }

      main { max-width: 860px; margin: 0 auto; padding: 0 1.5rem; }
      section { padding: 3.5rem 0; }

      .hero { padding: 5rem 0 3rem; }
      .eyebrow { color: var(--accent); margin-bottom: 0.8rem; }
      .cursor { animation: blink 1.1s steps(1) infinite; margin-left: 2px; }
      @keyframes blink { 50% { opacity: 0; } }
      .hero h1 {
        font-size: clamp(2.5rem, 7vw, 4rem);
        letter-spacing: -0.02em;
        line-height: 1.1;
      }
      .headline {
        font-size: clamp(1.15rem, 3vw, 1.45rem);
        color: var(--text-dim);
        margin-top: 0.9rem;
        max-width: 40ch;
      }
      .headline strong { color: var(--text); }
      .sub { margin-top: 0.9rem; color: var(--text-dim); }
      .hero-links { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.8rem; }
      .btn {
        display: inline-block;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.55rem 1.1rem;
        color: var(--text);
        font-weight: 500;
        transition: transform 0.15s, border-color 0.15s, background 0.15s;
      }
      .btn:hover {
        text-decoration: none;
        border-color: var(--accent);
        transform: translateY(-2px);
      }
      .btn.primary {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
      }
      :root[data-theme='dark'] .btn.primary { color: #0f172a; }
      @media (prefers-color-scheme: dark) {
        :root:not([data-theme='light']) .btn.primary { color: #0f172a; }
      }
      .btn.big { font-size: 1.05rem; padding: 0.7rem 1.4rem; }

      .stats {
        display: flex;
        flex-wrap: wrap;
        gap: 2.5rem;
        margin-top: 3rem;
      }
      .stats dt {
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--accent);
        font-family: ui-monospace, Menlo, monospace;
      }
      .stats dd { color: var(--text-dim); font-size: 0.92rem; }

      h2 { font-size: 1.6rem; margin-bottom: 1.2rem; letter-spacing: -0.01em; }
      section p + p { margin-top: 0.9rem; }
      section > p { max-width: 62ch; }

      .timeline {
        list-style: none;
        padding: 0;
        position: relative;
        border-left: 2px solid var(--border);
        margin-left: 0.4rem;
      }
      .job {
        position: relative;
        padding: 0 0 2.2rem 1.6rem;
      }
      .job::before {
        content: '';
        position: absolute;
        left: -7px;
        top: 0.45rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--bg);
        border: 2px solid var(--accent);
      }
      .job h3 { font-size: 1.12rem; }
      .job .at { color: var(--accent); font-weight: 600; }
      .period { color: var(--text-dim); margin: 0.15rem 0 0.6rem; }
      .job p { max-width: 60ch; }

      .tags {
        list-style: none;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0.7rem;
      }
      .tags li {
        background: var(--accent-soft);
        color: var(--accent);
        border-radius: 999px;
        padding: 0.18rem 0.75rem;
        font-size: 0.82rem;
        font-family: ui-monospace, Menlo, monospace;
      }

      .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: 1.2rem;
      }
      .skill-group {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.3rem;
      }
      .skill-group h3 { font-size: 0.95rem; color: var(--accent); margin-bottom: 0.8rem; }

      .contact { text-align: center; padding-bottom: 5rem; }
      .contact p { margin: 0 auto 1.6rem; }

      footer {
        border-top: 1px solid var(--border);
        text-align: center;
        padding: 2rem 1.5rem;
        color: var(--text-dim);
        font-size: 0.85rem;
      }
      footer p + p { margin-top: 0.4rem; }

      .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .reveal.visible { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        .cursor { animation: none; }
        html { scroll-behavior: auto; }
      }

      @media (max-width: 640px) {
        .nav nav a:not(:last-of-type) { display: none; }
        .stats { gap: 1.6rem; }
      }
    </style>
  </body>
</html>
