---
import Base from '../layouts/Base.astro';

const experience = [
  {
    role: 'Software Development Engineer',
    company: 'Mapbox',
    period: 'May 2025 – Present',
    location: 'Remote',
    blurb: 'Building map telemetry and metrics systems. Every map interaction tells a story, and my team makes sure we hear it.',
    tags: ['Data Pipelines', 'Agentic AI', 'Telemetry'],
  },
  {
    role: 'Software Engineer',
    company: 'Amazon',
    period: 'Feb 2024 – May 2025',
    location: 'Dallas, TX',
    blurb: 'Workplace Experience team. Built data pipelines and agentic AI tooling that made office life smarter.',
    tags: ['Agentic AI', 'Data Pipelines'],
  },
  {
    role: 'AI Training & Evaluation Engineer',
    company: 'Mercor',
    period: 'Nov 2023 – Apr 2025',
    location: 'Remote · Contract',
    blurb: 'Evaluated AI agent traces, designed rubrics for reasoning quality and built labeled datasets for fine-tuning. Taught models to think a little straighter.',
    tags: ['AI Evaluation', 'Rubrics', 'Agentic Automation'],
  },
  {
    role: 'Senior Software Engineer',
    company: 'Avalara',
    period: 'Sep 2022 – Dec 2023',
    location: 'Remote',
    blurb: 'Tax compliance at scale. Kept event-driven services humming with Kubernetes and Kafka.',
    tags: ['Kubernetes', 'Apache Kafka'],
  },
  {
    role: 'Software Engineer',
    company: 'Amazon',
    period: 'Aug 2016 – Jul 2022',
    location: 'Remote',
    blurb: 'Six years of microservices, serverless and everything in between. First tour at Amazon, where I learned to build things that survive Prime Day.',
    tags: ['Microservices', 'AWS Lambda', 'AWS'],
  },
];

const skills = {
  'Systems & Infra': ['Distributed Systems', 'Microservices', 'Kubernetes', 'AWS', 'AWS Lambda', 'Cloud Architecture'],
  'Data & APIs': ['Scalable APIs', 'Data Pipelines', 'Apache Kafka', 'Telemetry & Metrics'],
  'AI': ['Agentic AI Development', 'AI Evaluation', 'Evaluation Rubrics', 'Agentic Automation'],
};

const yearsOfExperience = new Date().getFullYear() - 2016;
---

<Base
  title="Anish Timsina · Software Engineer"
  description="Anish Timsina is a senior software engineer working on distributed systems, cloud infrastructure and scalable APIs. Currently building map telemetry at Mapbox."
>
  <section class="hero">
    <div class="glow" aria-hidden="true"></div>
    <p class="eyebrow mono">$ whoami</p>
    <h1 class="grad-text">Anish Timsina</h1>
    <p class="headline">
      Senior Software Engineer building
      <span class="mono typed-wrap"><span id="typed">distributed systems</span><span class="cursor">▊</span></span>
    </p>
    <p class="sub">
      Currently making maps smarter at <a href="https://www.mapbox.com" rel="noopener">Mapbox</a>.
      <button id="journey-btn" class="journey" title="See the journey">Based in Fort Worth, Texas 🗺️</button>
    </p>
    <div class="hero-links">
      <a class="btn primary" href="mailto:timsina.anish@gmail.com">Say hello</a>
      <a class="btn" href="https://www.linkedin.com/in/anishtimsina" rel="noopener">LinkedIn</a>
      <a class="btn" href="https://github.com/timanish" rel="noopener">GitHub</a>
      <button class="btn journey-open" type="button">🗺️&nbsp;My journey</button>
    </div>
    <dl class="stats reveal">
      <div><dt>{yearsOfExperience}+</dt><dd>years shipping software</dd></div>
      <div><dt>2</dt><dd>tours at Amazon</dd></div>
      <div><dt>∞</dt><dd>telemetry events wrangled</dd></div>
    </dl>
  </section>

  <section id="about" class="reveal">
    <h2><span class="mono accent">01.</span> About</h2>
    <p>
      I'm a software engineer with nearly a decade of experience across Amazon, Avalara,
      Mercor and Mapbox. I like systems that stay up, APIs that scale and dashboards that
      tell the truth.
    </p>
    <p>
      These days I work on map telemetry and metrics at Mapbox. Before that I built
      agentic AI tools and data pipelines at Amazon, kept tax software compliant at
      Avalara and taught AI models to reason better at Mercor. I care about product
      reliability, developer productivity and code that doesn't page anyone at 3 am.
    </p>
  </section>

  <section id="experience" class="reveal">
    <h2><span class="mono accent">02.</span> Experience</h2>
    <ol class="timeline">
      {experience.map((job) => (
        <li class="job reveal">
          <div class="job-head">
            <h3>{job.role} <span class="at">@ {job.company}</span></h3>
            <p class="mono period">{job.period} · {job.location}</p>
          </div>
          <p>{job.blurb}</p>
          <ul class="tags">
            {job.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </li>
      ))}
    </ol>
  </section>

  <section id="skills" class="reveal">
    <h2><span class="mono accent">03.</span> Skills</h2>
    <div class="skills-grid">
      {Object.entries(skills).map(([group, items]) => (
        <div class="skill-group">
          <h3 class="mono">{group}</h3>
          <ul class="tags">
            {items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section id="education" class="reveal">
    <h2><span class="mono accent">04.</span> Education</h2>
    <p>
      <strong>University of Nebraska–Lincoln</strong><br />
      Go Huskers.
    </p>
  </section>

  <section id="contact" class="reveal">
    <h2><span class="mono accent">05.</span> Contact</h2>
    <p>
      Whether you want to talk distributed systems, maps or the best momo in Texas,
      my inbox is open.
    </p>
    <a class="btn primary big" href="mailto:timsina.anish@gmail.com">timsina.anish@gmail.com</a>
  </section>

  <div id="map-modal" hidden>
    <div class="map-backdrop"></div>
    <div class="map-card" role="dialog" aria-label="The journey from Kathmandu to Fort Worth">
      <button id="map-close" aria-label="Close map">✕</button>
      <div id="map"></div>
      <p class="mono map-caption">Jhapa → Dhulikhel → Lincoln → Seattle → Austin → Fort Worth → Irving</p>
    </div>
  </div>

  <script>
    // Typewriter in the hero headline
    const phrases = [
      'distributed systems.',
      'scalable APIs.',
      'data pipelines.',
      'agentic AI tools.',
      'maps that know things.',
    ];
    const typed = document.getElementById('typed');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (typed && !reduceMotion) {
      let phrase = 0;
      let chars = phrases[0].length;
      let deleting = true;
      const tick = () => {
        chars += deleting ? -1 : 1;
        typed.textContent = phrases[phrase].slice(0, chars);
        let delay = deleting ? 40 : 75;
        if (deleting && chars === 0) {
          deleting = false;
          phrase = (phrase + 1) % phrases.length;
          delay = 300;
        } else if (!deleting && chars === phrases[phrase].length) {
          deleting = true;
          delay = 2200;
        }
        setTimeout(tick, delay);
      };
      setTimeout(tick, 2200);
    } else if (typed) {
      typed.textContent = 'distributed systems.';
    }

    // Journey globe (MapLibre GL, loaded on demand)
    const modal = document.getElementById('map-modal')!;
    const journeyBtn = document.getElementById('journey-btn');
    const closeBtn = document.getElementById('map-close');
    let mapReady = false;

    const stops: Array<[number, number, string]> = [
      [87.99, 26.65, '🌱 Jhapa'],
      [85.5433, 27.6203, '🏔️ Dhulikhel'],
      [-96.7026, 40.8136, '🎓 Lincoln'],
      [-122.3321, 47.6062, '🌧️ Seattle'],
      [-97.7431, 30.2672, '🎸 Austin'],
      [-97.3308, 32.7555, '🤠 Fort Worth'],
      [-96.9489, 32.814, '📍 Irving'],
    ];

    function loadOnce(tag: 'script' | 'link', url: string) {
      return new Promise<void>((resolve, reject) => {
        if (document.querySelector(`[data-src="${url}"]`)) return resolve();
        const el = document.createElement(tag);
        el.dataset.src = url;
        if (tag === 'script') {
          (el as HTMLScriptElement).src = url;
          el.onload = () => resolve();
          el.onerror = reject;
        } else {
          (el as HTMLLinkElement).rel = 'stylesheet';
          (el as HTMLLinkElement).href = url;
          resolve();
        }
        document.head.appendChild(el);
      });
    }

    async function initMap() {
      if (mapReady) return;
      mapReady = true;
      await Promise.all([
        loadOnce('script', 'https://unpkg.com/maplibre-gl@5.6.0/dist/maplibre-gl.js'),
        loadOnce('link', 'https://unpkg.com/maplibre-gl@5.6.0/dist/maplibre-gl.css'),
      ]);
      const maplibregl = (window as any).maplibregl;
      const dark = document.documentElement.dataset.theme
        ? document.documentElement.dataset.theme === 'dark'
        : window.matchMedia('(prefers-color-scheme: dark)').matches;
      const style = dark
        ? 'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json'
        : 'https://basemaps.cartocdn.com/gl/positron-gl-style/style.json';
      const map = new maplibregl.Map({
        container: 'map',
        style,
        center: stops[0].slice(0, 2),
        zoom: 2.2,
        attributionControl: { compact: true },
      });
      map.on('style.load', () => {
        map.setProjection({ type: 'globe' });
        map.addSource('route', {
          type: 'geojson',
          data: {
            type: 'Feature',
            properties: {},
            geometry: { type: 'LineString', coordinates: stops.map((s) => s.slice(0, 2)) },
          },
        });
        map.addLayer({
          id: 'route',
          type: 'line',
          source: 'route',
          paint: { 'line-color': '#34d399', 'line-width': 2.5, 'line-dasharray': [1.5, 1.5] },
        });
      });
      for (const [lng, lat, label] of stops) {
        const el = document.createElement('div');
        el.className = 'stop-marker mono';
        el.textContent = label;
        new maplibregl.Marker({ element: el, anchor: 'bottom' }).setLngLat([lng, lat]).addTo(map);
      }
      const tour = [
        { center: [86.75, 27.15], zoom: 6, duration: 2400 },
        { center: stops[2].slice(0, 2), zoom: 4.8, duration: 4200 },
        { center: stops[3].slice(0, 2), zoom: 5.5, duration: 2600 },
        { center: stops[4].slice(0, 2), zoom: 5.5, duration: 2600 },
        { center: [-97.14, 32.79], zoom: 8, duration: 2600 },
      ];
      let leg = 0;
      const nextLeg = () => {
        if (leg >= tour.length || modal.hidden) return;
        map.flyTo({ ...tour[leg], essential: false });
        leg++;
        map.once('moveend', () => setTimeout(nextLeg, 900));
      };
      setTimeout(nextLeg, 600);
    }

    function openModal() {
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      initMap();
    }
    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
    }
    journeyBtn?.addEventListener('click', openModal);
    document.querySelectorAll('.journey-open').forEach((b) => b.addEventListener('click', openModal));
    closeBtn?.addEventListener('click', closeModal);
    modal.querySelector('.map-backdrop')?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  </script>

  <style>
    .hero { padding: 5rem 0 3rem; position: relative; }
    .glow {
      position: absolute;
      top: -4rem;
      left: -8rem;
      width: 30rem;
      height: 30rem;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent-soft), transparent 65%);
      filter: blur(50px);
      pointer-events: none;
      z-index: -1;
    }
    .eyebrow { color: var(--accent); margin-bottom: 0.8rem; }
    .cursor { animation: blink 1.1s steps(1) infinite; margin-left: 2px; color: var(--accent); }
    @keyframes blink { 50% { opacity: 0; } }
    .hero h1 { font-size: clamp(2.5rem, 7vw, 4rem); }
    .headline {
      font-size: clamp(1.15rem, 3vw, 1.4rem);
      color: var(--text);
      margin-top: 0.9rem;
      max-width: 46ch;
      min-height: 2.6em;
    }
    .typed-wrap { color: var(--accent); font-weight: 700; }
    .sub { margin-top: 0.9rem; color: var(--text-dim); }
    .journey-open {
      background: none;
      font: inherit;
      cursor: pointer;
    }
    .journey {
      background: none;
      border: none;
      padding: 0;
      font: inherit;
      color: var(--text-dim);
      cursor: pointer;
      border-bottom: 1px dashed var(--accent);
    }
    .journey:hover { color: var(--accent); }
    .hero-links { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.8rem; }

    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 2.5rem;
      margin-top: 3rem;
    }
    .stats dt {
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--accent);
      font-family: 'JetBrains Mono', ui-monospace, Menlo, monospace;
      transition: color 0.3s;
    }
    .stats dd { color: var(--text-dim); font-size: 0.92rem; }

    .timeline {
      list-style: none;
      padding: 0;
      position: relative;
      border-left: 2px solid var(--border);
      margin-left: 0.4rem;
    }
    .job {
      position: relative;
      padding: 0.8rem 1rem 1rem 1.6rem;
      margin-bottom: 1.2rem;
      border-radius: 12px;
      transition: background 0.2s, transform 0.2s;
    }
    .job:hover {
      background: var(--bg-card);
      transform: translateX(4px);
    }
    .job::before {
      content: '';
      position: absolute;
      left: -7px;
      top: 1.25rem;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--bg);
      border: 2px solid var(--accent);
      transition: background 0.2s, box-shadow 0.2s;
    }
    .job:hover::before {
      background: var(--accent);
      box-shadow: 0 0 10px var(--accent);
    }
    .job h3 { font-size: 1.12rem; }
    .job .at { color: var(--accent); font-weight: 600; }
    .period { color: var(--text-dim); margin: 0.15rem 0 0.6rem; }
    .job p { max-width: 60ch; }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1.2rem;
    }
    .skill-group {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 1.3rem;
      transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .skill-group:hover {
      transform: translateY(-4px);
      border-color: var(--accent);
      box-shadow: 0 8px 24px var(--accent-soft);
    }
    .skill-group h3 { font-size: 0.95rem; color: var(--accent); margin-bottom: 0.8rem; }

    #contact { padding-bottom: 5rem; }
    #contact .btn { margin-top: 1.4rem; }

    @media (prefers-reduced-motion: reduce) {
      .cursor { animation: none; }
      .skill-group:hover, .job:hover { transform: none; }
    }
    @media (max-width: 640px) {
      .job { padding-left: 1.3rem; }
      .stats { gap: 1.6rem; }
    }
  </style>

  <style is:global>
    #map-modal { position: fixed; inset: 0; z-index: 50; }
    .map-backdrop {
      position: absolute;
      inset: 0;
      background: #020617b3;
      backdrop-filter: blur(4px);
    }
    .map-card {
      position: absolute;
      inset: 50% auto auto 50%;
      transform: translate(-50%, -50%);
      width: min(92vw, 720px);
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 0.9rem;
      box-shadow: 0 24px 80px #02061799;
    }
    #map {
      width: 100%;
      height: min(60vh, 440px);
      border-radius: 10px;
      overflow: hidden;
    }
    .map-caption {
      text-align: center;
      color: var(--text-dim);
      margin-top: 0.7rem;
      font-size: 0.85rem;
    }
    #map-close {
      position: absolute;
      top: -0.8rem;
      right: -0.8rem;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text);
      cursor: pointer;
      font-size: 1rem;
      z-index: 2;
    }
    #map-close:hover { border-color: var(--accent); color: var(--accent); }
    .stop-marker {
      background: var(--bg-card);
      color: var(--text);
      border: 1px solid var(--accent);
      border-radius: 999px;
      padding: 0.1rem 0.6rem;
      font-size: 0.78rem;
      white-space: nowrap;
      box-shadow: 0 2px 10px #02061755;
    }
  </style>
</Base>
