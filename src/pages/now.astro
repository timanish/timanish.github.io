---
import Base from '../layouts/Base.astro';

const updated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long' });

const now = {
  working: [
    'Map telemetry and metrics at Mapbox. If a map moved, my team probably counted it.',
    'This website. It started as a single page and is slowly becoming a hobby.',
  ],
  tinkering: [
    'Agentic AI tooling and evaluation. Teaching agents to use tools without face-planting.',
    'Data pipelines that are boring in the best possible way.',
  ],
  life: [
    'Settling deeper into Fort Worth, Texas.',
    'Ongoing field research into the best momo in the DFW metroplex. Results inconclusive, sample size growing.',
  ],
};
---

<Base
  title="Now · Anish Timsina"
  description="What Anish Timsina is working on, tinkering with and up to right now."
>
  <section class="now-hero">
    <p class="eyebrow mono">$ uptime</p>
    <h1 class="grad-text">Now</h1>
    <p class="intro">
      What I'm up to at the moment, in the spirit of
      <a href="https://nownownow.com/about" rel="noopener">nownownow.com</a>.
      Last updated {updated}.
    </p>
  </section>

  <section class="reveal">
    <h2><span class="mono accent">01.</span> Working on</h2>
    <ul class="now-list">
      {now.working.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="reveal">
    <h2><span class="mono accent">02.</span> Tinkering with</h2>
    <ul class="now-list">
      {now.tinkering.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="reveal">
    <h2><span class="mono accent">03.</span> Life</h2>
    <ul class="now-list">
      {now.life.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="reveal back-home">
    <a class="btn" href="/">← Back home</a>
  </section>

  <style>
    .now-hero { padding: 5rem 0 1rem; }
    .eyebrow { color: var(--accent); margin-bottom: 0.8rem; }
    .now-hero h1 { font-size: clamp(2.5rem, 7vw, 4rem); }
    .intro { color: var(--text-dim); margin-top: 0.9rem; max-width: 52ch; }
    .now-list {
      list-style: none;
      padding: 0;
      max-width: 62ch;
    }
    .now-list li {
      position: relative;
      padding-left: 1.4rem;
      margin-bottom: 0.7rem;
    }
    .now-list li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: var(--accent);
    }
    .back-home { padding-bottom: 5rem; }
  </style>
</Base>
